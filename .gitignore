# signal-cli link state — contains your device KEYS. Never commit this.
signal-cli-data/

# Per-user runtime data — your number, groups, message, and image paths. Never
# commit. config.toml is created from config.example.toml on first run.
config.toml
groups.txt
message.txt
attachments.txt

# Generated launchd job (machine-specific paths)
com.user.signal-broadcast.plist

# Dock launcher built locally by Setup (bakes in this machine's absolute path)
Signal Broadcast.app/

# Run logs, failure ledgers, last-run marker
logs/*
!logs/.gitkeep

# Bundled JVM build of signal-cli (~110 MB), downloaded by Setup per machine
vendor/

# Docker "pixel-sandbox" persistent state (PERSIST=1) — holds link KEYS. Never commit.
.sandbox-data/

# Images uploaded through the mobile web UI (per-user content).
webui-uploads/

__pycache__/
